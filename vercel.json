{
  "buildCommand": "vite build",
  "devCommand": "vite --port $PORT",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "env": {
    "GEMINI_API_KEY": "@gemini_api_key",
    "DEMO_MODE": "0",
    "VITE_APP_NAME": "IntelliAxis"
  }
}